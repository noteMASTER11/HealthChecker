<Window x:Class="HealthChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HealthChecker"
        Width="1220"
        Height="860"
        MinWidth="980"
        MinHeight="680"
        Background="#020617"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0EA5E9" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#0EA5E9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20"
                CornerRadius="20"
                BorderBrush="#334155"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0B1220" Offset="0" />
                    <GradientStop Color="#0F172A" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="HealthChecker"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#F8FAFC"
                               FontFamily="Bahnschrift" />
                    <TextBlock Text="Domain and IP monitoring every second with persisted availability history."
                               Margin="0,6,0,0"
                               Foreground="#94A3B8"
                               FontSize="14"
                               FontFamily="Bahnschrift" />
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="{Binding MonitoringButtonText}"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding ToggleMonitoringCommand}" />
                    <Button Content="Probe Now"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding ProbeNowCommand}" />
                    <Button Content="To Tray"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0"
                            Click="TrayButton_OnClick" />
                </StackPanel>

                <Grid Grid.Row="2" Grid.ColumnSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Name"
                               Foreground="#94A3B8"
                               FontSize="12"
                               FontFamily="Bahnschrift"
                               Margin="0,0,10,0" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Domain or IP"
                               Foreground="#94A3B8"
                               FontSize="12"
                               FontFamily="Bahnschrift"
                               Margin="0,0,10,0" />
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="Description"
                               Foreground="#94A3B8"
                               FontSize="12"
                               FontFamily="Bahnschrift"
                               Margin="0,0,10,0" />

                    <TextBox Grid.Row="2"
                             Grid.Column="0"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding NewAddress, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding AddTargetCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBox Grid.Row="2"
                             Grid.Column="2"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="2"
                            Grid.Column="3"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Add Target"
                            Command="{Binding AddTargetCommand}" />
                </Grid>

                <StackPanel Grid.Row="4"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox Content="Start with Windows (launch in tray)"
                              Foreground="#CBD5E1"
                              IsChecked="{Binding StartWithWindows}"
                              FontFamily="Bahnschrift"
                              Margin="0,0,20,0" />
                    <TextBlock Text="State file: %AppData%\\HealthChecker\\state.json"
                               Foreground="#64748B"
                               FontFamily="Bahnschrift"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
        <Border CornerRadius="20"
                BorderBrush="#1E293B"
                BorderThickness="1"
                Padding="16"
                Background="#050B16"
                Visibility="{Binding IsListView, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Targets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,0,14"
                                      Background="#0B1220"
                                      BorderBrush="#1E293B"
                                      BorderThickness="1"
                                      HorizontalContentAlignment="Stretch"
                                      IsExpanded="{Binding IsExpanded}">
                                <Expander.Header>
                                    <Border Padding="10,10,10,8"
                                            Background="#071227"
                                            CornerRadius="8">
                                        <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="28"
                                                Height="28"
                                                CornerRadius="14"
                                                BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0F172A" />
                                                    <Setter Property="BorderBrush" Value="#334155" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True">
                                                            <Setter Property="Background" Value="#22C55E" />
                                                            <Setter Property="BorderBrush" Value="#22C55E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value=">" />
                                                        <Setter Property="Foreground" Value="#CBD5E1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True">
                                                                <Setter Property="Text" Value="v" />
                                                                <Setter Property="Foreground" Value="#0B1220" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,18,0">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#F8FAFC"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       FontFamily="Bahnschrift" />
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="#94A3B8"
                                                       FontSize="12"
                                                       FontFamily="Bahnschrift"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="IP" Foreground="#64748B" FontSize="11" FontFamily="Bahnschrift" />
                                            <TextBlock Text="{Binding ResolvedIpDisplay}" Foreground="#E2E8F0" FontFamily="Bahnschrift" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="Ping" Foreground="#64748B" FontSize="11" FontFamily="Bahnschrift" />
                                            <TextBlock Text="{Binding CurrentPingDisplay}" Foreground="#E2E8F0" FontFamily="Bahnschrift" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Margin="0,0,8,0"
                                                     Fill="{Binding IsOnline, Converter={StaticResource StatusBrushConverter}}" />
                                            <TextBlock Text="{Binding StatusText}" Foreground="#CBD5E1" FontFamily="Bahnschrift" />
                                        </StackPanel>

                                        <Button Grid.Column="5"
                                                Content="X"
                                                Width="28"
                                                Height="28"
                                                FontSize="16"
                                                Background="#7F1D1D"
                                                Foreground="#FEE2E2"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </Expander.Header>

                                <Border Margin="8,2,8,8" Padding="14" Background="#0F172A" CornerRadius="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="16" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="14" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="126" />
                                            </Grid.ColumnDefinitions>

                                            <UniformGrid Grid.Column="0" Columns="5" Margin="0,0,10,0">
                                                <Border Background="#111827" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Last Probe" Foreground="#64748B" FontSize="11" FontFamily="Bahnschrift" />
                                                        <TextBlock Text="{Binding LastCheckDisplay}" Foreground="#F8FAFC" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#111827" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Last Online" Foreground="#64748B" FontSize="11" FontFamily="Bahnschrift" />
                                                        <TextBlock Text="{Binding LastSeenDisplay}" Foreground="#F8FAFC" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#111827" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Uptime (1h)" Foreground="#64748B" FontSize="11" FontFamily="Bahnschrift" />
                                                        <TextBlock Text="{Binding UptimeLastHourPercent, StringFormat={}{0:F1}%}" Foreground="#F8FAFC" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#111827" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Avg Ping (1h)" Foreground="#64748B" FontSize="11" FontFamily="Bahnschrift" />
                                                        <TextBlock Text="{Binding AveragePingLastHourDisplay}" Foreground="#F8FAFC" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#111827" CornerRadius="10" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Min / Max Ping" Foreground="#64748B" FontSize="11" FontFamily="Bahnschrift" />
                                                        <TextBlock Foreground="#F8FAFC" FontFamily="Bahnschrift" FontWeight="SemiBold">
                                                            <Run Text="{Binding MinPingLastHourDisplay, Mode=OneWay}" />
                                                            <Run Text=" / " />
                                                            <Run Text="{Binding MaxPingLastHourDisplay, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                <Button Content="Tracert"
                                                        Height="38"
                                                        VerticalAlignment="Center"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Command="{Binding DataContext.OpenTraceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="#111827" CornerRadius="12" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Availability (last 60 probes)" Foreground="#CBD5E1" FontFamily="Bahnschrift" Margin="0,0,0,10" />
                                                    <ItemsControl ItemsSource="{Binding RecentSamples}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="6"
                                                                        Height="24"
                                                                        Margin="0,0,2,0"
                                                                        CornerRadius="2"
                                                                        Cursor="Hand"
                                                                        Background="{Binding IsOnline, Converter={StaticResource StatusBrushConverter}}">
                                                                    <Border.ToolTip>
                                                                        <ToolTip Background="#0B1220"
                                                                                 BorderBrush="#334155"
                                                                                 Foreground="#E2E8F0">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding IsOnline, Converter={StaticResource StatusTextConverter}, StringFormat=Status: {0}}" />
                                                                                <TextBlock Text="{Binding PingMs, StringFormat=Ping: {0} ms, TargetNullValue=Ping: n/a}" />
                                                                                <TextBlock Text="{Binding Timestamp, StringFormat=Time: {0:HH:mm:ss}}" />
                                                                            </StackPanel>
                                                                        </ToolTip>
                                                                    </Border.ToolTip>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="{Binding NoDataHint}" Margin="0,8,0,0" Foreground="#64748B" FontFamily="Bahnschrift" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" Background="#111827" CornerRadius="12" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="Ping trend (last 60 probes)" Foreground="#CBD5E1" FontFamily="Bahnschrift" Margin="0,0,0,10" />
                                                    <ItemsControl ItemsSource="{Binding RecentSamples}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="6" Height="80" Margin="0,0,2,0">
                                                                    <Border VerticalAlignment="Bottom"
                                                                            CornerRadius="2"
                                                                            Cursor="Hand"
                                                                            Background="{Binding IsOnline, Converter={StaticResource StatusBrushConverter}}">
                                                                        <Border.Height>
                                                                            <MultiBinding Converter="{StaticResource PingHeightConverter}">
                                                                                <Binding Path="PingMs" />
                                                                                <Binding Path="DataContext.MaxRecentPing" RelativeSource="{RelativeSource AncestorType=Expander}" />
                                                                            </MultiBinding>
                                                                        </Border.Height>
                                                                        <Border.ToolTip>
                                                                            <ToolTip Background="#0B1220"
                                                                                     BorderBrush="#334155"
                                                                                     Foreground="#E2E8F0">
                                                                                <StackPanel>
                                                                                    <TextBlock Text="{Binding PingMs, StringFormat=Ping: {0} ms, TargetNullValue=Ping: n/a}" />
                                                                                    <TextBlock Text="{Binding IsOnline, Converter={StaticResource StatusTextConverter}, StringFormat=Status: {0}}" />
                                                                                    <TextBlock Text="{Binding Timestamp, StringFormat=Time: {0:HH:mm:ss}}" />
                                                                                </StackPanel>
                                                                            </ToolTip>
                                                                        </Border.ToolTip>
                                                                    </Border>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="{Binding NoDataHint}" Margin="0,8,0,0" Foreground="#64748B" FontFamily="Bahnschrift" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="4"
                                                   Text="{Binding LastError}"
                                                   Foreground="#FCA5A5"
                                                   FontFamily="Bahnschrift" />
                                    </Grid>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

            <Border CornerRadius="20"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Padding="16"
                    Background="#050B16"
                    Visibility="{Binding IsTraceView, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Back"
                                Width="88"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding BackToListCommand}" />

                        <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TraceCaption}" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" FontFamily="Bahnschrift" />
                            <TextBlock Text="{Binding TraceSession.StatusText}" Foreground="#94A3B8" FontSize="12" FontFamily="Bahnschrift" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="Stop"
                                Width="90"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0"
                                Command="{Binding StopTraceCommand}" />
                    </Grid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding TraceSession.Hops}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderBrush="#334155"
                              BorderThickness="1"
                              Background="#0B1220"
                              RowBackground="#0F172A"
                              AlternatingRowBackground="#111827"
                              Foreground="#E2E8F0"
                              ColumnHeaderHeight="34"
                              FontFamily="Bahnschrift"
                              FontSize="13">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#111827" />
                                <Setter Property="Foreground" Value="#CBD5E1" />
                                <Setter Property="BorderBrush" Value="#334155" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,6" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="*" />
                            <DataGridTextColumn Header="Nr" Binding="{Binding HopNumber}" Width="58" />
                            <DataGridTextColumn Header="Loss %" Binding="{Binding LossPercent}" Width="72" />
                            <DataGridTextColumn Header="Sent" Binding="{Binding Sent}" Width="70" />
                            <DataGridTextColumn Header="Recv" Binding="{Binding Received}" Width="70" />
                            <DataGridTextColumn Header="Best" Binding="{Binding BestDisplay}" Width="70" />
                            <DataGridTextColumn Header="Avg" Binding="{Binding AvgDisplay}" Width="70" />
                            <DataGridTextColumn Header="Worst" Binding="{Binding WorstDisplay}" Width="70" />
                            <DataGridTextColumn Header="Last" Binding="{Binding LastDisplay}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="8,10,8,0"
                   Text="{Binding StatusMessage}"
                   Foreground="#94A3B8"
                   FontFamily="Bahnschrift" />
    </Grid>
</Window>


