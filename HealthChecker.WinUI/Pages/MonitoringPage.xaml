<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HealthChecker_WinUI.Pages.MonitoringPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Monitoring"
                               FontSize="34"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Per-target live statistics + Full History."
                               Opacity="0.82" />
                </StackPanel>

                <Button Grid.Column="1" Content="{Binding MonitoringButtonText}" Click="ToggleMonitoring_Click" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Probe Now" Click="ProbeNow_Click" />
            </Grid>

            <StackPanel Visibility="{Binding ListPaneVisibility}" Spacing="16">
                <Border CornerRadius="12" Padding="16" BorderThickness="1" BorderBrush="#2E4366" Background="#141E31">
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Opacity="0.78" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Domain or IP" Opacity="0.78" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Description" Opacity="0.78" />

                        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewName, Mode=TwoWay}" PlaceholderText="Google DNS" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewAddress, Mode=TwoWay}" PlaceholderText="8.8.8.8 or example.com" />
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding NewDescription, Mode=TwoWay}" PlaceholderText="Public resolver" />
                        <Button Grid.Row="1" Grid.Column="3" Content="Add Target" Click="AddTarget_Click" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="4"
                                   Text="{Binding StatusMessage}"
                                   Opacity="0.75"
                                   TextWrapping="WrapWholeWords" />
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding Targets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="14" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#2E4366" Background="#121C2E">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{Binding Description}" Opacity="0.74" TextWrapping="WrapWholeWords" MaxLines="3" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="Address / IP" Opacity="0.68" />
                                            <TextBlock TextWrapping="WrapWholeWords">
                                                <Run Text="{Binding Address}" />
                                                <Run Text="  (" />
                                                <Run Text="{Binding ResolvedIpDisplay}" />
                                                <Run Text=")" />
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <TextBlock Text="Current Ping" Opacity="0.68" />
                                            <TextBlock Text="{Binding CurrentPingDisplay}" FontWeight="SemiBold" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}" />
                                            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" />
                                        </StackPanel>

                                        <Button Grid.Column="4" Content="Remove" Tag="{Binding}" Click="RemoveTarget_Click" Margin="0,0,8,0" />
                                        <Button Grid.Column="5"
                                                Tag="{Binding}"
                                                Click="ToggleExpand_Click"
                                                FontFamily="Segoe MDL2 Assets"
                                                Content="{Binding ExpandGlyph}"
                                                Width="36"
                                                Height="36"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top" />
                                    </Grid>

                                    <Grid Visibility="{Binding DetailsVisibility}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Last Probe" Opacity="0.68" />
                                                <TextBlock Text="{Binding LastCheckDisplay}" FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="Last Online" Opacity="0.68" />
                                                <TextBlock Text="{Binding LastSeenDisplay}" FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Spacing="2">
                                                <TextBlock Text="Uptime (1h)" Opacity="0.68" />
                                                <TextBlock Text="{Binding UptimeLastHourDisplay}" FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Spacing="2">
                                                <TextBlock Text="Avg Ping (1h)" Opacity="0.68" />
                                                <TextBlock Text="{Binding AveragePingLastHourDisplay}" FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="4" Spacing="2">
                                                <TextBlock Text="Min / Max Ping" Opacity="0.68" />
                                                <TextBlock FontWeight="SemiBold">
                                                    <Run Text="{Binding MinPingLastHourDisplay}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding MaxPingLastHourDisplay}" />
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="5" Content="Tracert" Tag="{Binding}" Click="OpenTrace_Click" MinWidth="88" VerticalAlignment="Bottom" />
                                        </Grid>

                                        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" CornerRadius="10" Padding="10" BorderThickness="1" BorderBrush="#2E4366" Background="#0F1728">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Availability (last 60 probes)" FontWeight="SemiBold" />
                                                    <Grid Height="62" VerticalAlignment="Bottom">
                                                        <ItemsControl ItemsSource="{Binding AvailabilityBars}" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="8"
                                                                            Height="{Binding Height}"
                                                                            VerticalAlignment="Bottom"
                                                                            CornerRadius="2"
                                                                            Background="{Binding Fill}"
                                                                            ToolTipService.ToolTip="{Binding ToolTip}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" CornerRadius="10" Padding="10" BorderThickness="1" BorderBrush="#2E4366" Background="#0F1728">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Ping trend (last 60 probes)" FontWeight="SemiBold" />
                                                    <Grid Height="62" VerticalAlignment="Bottom">
                                                        <ItemsControl ItemsSource="{Binding PingBars}" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="8"
                                                                            Height="{Binding Height}"
                                                                            VerticalAlignment="Bottom"
                                                                            CornerRadius="2"
                                                                            Background="{Binding Fill}"
                                                                            ToolTipService.ToolTip="{Binding ToolTip}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Grid.Row="2" CornerRadius="10" Padding="10" Margin="0,12,0,0" BorderThickness="1" BorderBrush="#2E4366" Background="#0F1728">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Full History (aggregated)" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FullHistoryHint}" Opacity="0.76" />
                                                <Grid Height="78" VerticalAlignment="Bottom">
                                                    <ItemsControl ItemsSource="{Binding FullHistoryBars}" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" Spacing="2" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="8"
                                                                        Height="{Binding Height}"
                                                                        VerticalAlignment="Bottom"
                                                                        CornerRadius="2"
                                                                        Background="{Binding Fill}"
                                                                        ToolTipService.ToolTip="{Binding ToolTip}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Border Visibility="{Binding TracePaneVisibility}" CornerRadius="12" Padding="14" BorderThickness="1" BorderBrush="#2E4366" Background="#121C2E">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Back" Click="BackFromTrace_Click" MinWidth="82" />

                        <StackPanel Grid.Column="1" Margin="12,0">
                            <TextBlock Text="{Binding TraceCaption}" FontSize="28" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding TraceStatusDisplay}" Opacity="0.8" />
                        </StackPanel>

                        <Button Grid.Column="2" Content="Stop" Click="StopTrace_Click" MinWidth="82" IsEnabled="{Binding IsTraceRunning}" />
                    </Grid>

                    <Border CornerRadius="10" Padding="8" BorderThickness="1" BorderBrush="#2E4366" Background="#0F1728">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Hostname" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Nr" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Loss %" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Sent" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Recv" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Best" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="Avg" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="7" Text="Worst" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="8" Text="Last" FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <ListView ItemsSource="{Binding TraceSession.Hops}" SelectionMode="None" Height="560">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Padding="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.2*" />
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Hostname}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Grid.Column="1" Text="{Binding HopNumber}" />
                                    <TextBlock Grid.Column="2" Text="{Binding LossPercent}" />
                                    <TextBlock Grid.Column="3" Text="{Binding Sent}" />
                                    <TextBlock Grid.Column="4" Text="{Binding Received}" />
                                    <TextBlock Grid.Column="5" Text="{Binding BestDisplay}" />
                                    <TextBlock Grid.Column="6" Text="{Binding AvgDisplay}" />
                                    <TextBlock Grid.Column="7" Text="{Binding WorstDisplay}" />
                                    <TextBlock Grid.Column="8" Text="{Binding LastDisplay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
