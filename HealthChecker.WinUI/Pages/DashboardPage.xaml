<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HealthChecker_WinUI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,24" Spacing="16">
            <TextBlock Text="Main"
                       FontSize="34"
                       FontWeight="SemiBold" />
            <TextBlock Text="Live fleet analytics across all monitored targets."
                       Opacity="0.8" />

            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="12" Padding="14" BorderThickness="1" BorderBrush="#2E4366" Background="#162134">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Total Targets" Opacity="0.75" />
                        <TextBlock Text="{Binding TotalTargets}" FontSize="28" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="12" Padding="14" BorderThickness="1" BorderBrush="#2E4366" Background="#162134">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Online / Offline" Opacity="0.75" />
                        <TextBlock FontSize="22" FontWeight="SemiBold">
                            <Run Text="{Binding OnlineTargets}" />
                            <Run Text=" / " />
                            <Run Text="{Binding OfflineTargets}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="12" Padding="14" BorderThickness="1" BorderBrush="#2E4366" Background="#162134">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Fleet Avg Ping (1h)" Opacity="0.75" />
                        <TextBlock Text="{Binding FleetAveragePingDisplay}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" CornerRadius="12" Padding="14" BorderThickness="1" BorderBrush="#2E4366" Background="#162134">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Fleet Uptime (1h)" Opacity="0.75" />
                        <TextBlock Text="{Binding FleetUptimeDisplay}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border CornerRadius="12" Padding="16" BorderThickness="1" BorderBrush="#2E4366" Background="#141E31">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Full History (Fleet)"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FleetHistoryHint}" Opacity="0.78" />
                        </StackPanel>

                        <Button Grid.Column="1" Content="{Binding MonitoringButtonText}" Click="ToggleMonitoring_Click" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Content="Probe Now" Click="ProbeNow_Click" />
                    </Grid>

                    <Border Height="88" CornerRadius="10" Padding="10" BorderThickness="1" BorderBrush="#2E4366" Background="#0F1728">
                        <ItemsControl ItemsSource="{Binding FleetHistoryBars}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="8"
                                            Height="{Binding Height}"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="2"
                                            Background="{Binding Fill}"
                                            ToolTipService.ToolTip="{Binding ToolTip}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Border>

            <Border CornerRadius="12" Padding="16" BorderThickness="1" BorderBrush="#2E4366" Background="#141E31">
                <StackPanel Spacing="6">
                    <TextBlock Text="Runtime" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StateStorePathDisplay}" Opacity="0.82" />
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.78" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
